<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<style>
  body { font-family: Helvetica, Arial, sans-serif; color: #1e293b; margin: 40px; font-size: 13px; }
  h1 { font-size: 22px; color: #0d9488; margin: 0 0 4px; }
  .sub { color: #64748b; margin-bottom: 28px; }
  .cards { display: flex; gap: 16px; margin-bottom: 28px; }
  .card { flex: 1; border: 1px solid #e2e8f0; border-radius: 8px; padding: 14px 16px; }
  .card .label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #94a3b8; }
  .card .value { font-size: 20px; font-weight: bold; margin-top: 4px; }
  .card .value.warn { color: #b45309; }
  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #94a3b8; border-bottom: 2px solid #0d9488; padding: 6px 8px; }
  td { padding: 9px 8px; border-bottom: 1px solid #e2e8f0; }
  .num { text-align: right; }
  .foot { margin-top: 32px; color: #94a3b8; font-size: 10px; }
</style>
</head>
<body>
  <h1>Monthly spend summary — {{ month_label }}</h1>
  <div class="sub">{{ company_name }} — accounts payable</div>

  <div class="cards">
    <div class="card">
      <div class="label">Total spend</div>
      <div class="value">£{{ "%.2f"|format(total_spend) }}</div>
    </div>
    <div class="card">
      <div class="label">Invoices processed</div>
      <div class="value">{{ invoice_count }}</div>
    </div>
    <div class="card">
      <div class="label">Anomalies flagged</div>
      <div class="value {% if anomaly_count %}warn{% endif %}">{{ anomaly_count }}</div>
    </div>
  </div>

  <table>
    <thead>
      <tr><th>Category</th><th class="num">Invoices</th><th class="num">Spend</th></tr>
    </thead>
    <tbody>
      {% for category, entry in by_category.items() %}
      <tr>
        <td>{{ category }}</td>
        <td class="num">{{ entry.count }}</td>
        <td class="num">£{{ "%.2f"|format(entry.total) }}</td>
      </tr>
      {% else %}
      <tr><td colspan="3">No supplier invoices recorded for this month.</td></tr>
      {% endfor %}
    </tbody>
  </table>

  <div class="foot">Generated automatically by Trinops Accounting. Figures are gross amounts as extracted from supplier invoices.</div>
</body>
</html>
