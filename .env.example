# --- Runtime mode -----------------------------------------------------------
# true  = no external services needed: seed invoices, seed supplier emails, outbox dir
# false = real Gmail inbox + outbound sending (requires Google OAuth credentials)
DEMO_MODE=true

# --- Admin API auth ----------------------------------------------------------
# Protects staff/admin endpoints when DEMO_MODE=false. Send it as the X-API-Key
# request header. Leave empty in demo mode (auth is disabled there).
ADMIN_API_KEY=

# --- Database ----------------------------------------------------------------
# SQLite for demo; swap for PostgreSQL in production, e.g.
# DATABASE_URL=postgresql+psycopg://user:pass@db:5432/accounting
DATABASE_URL=sqlite:///./data/accounting.db

# --- Scheduler ----------------------------------------------------------------
# AP inbox poll interval and AR overdue/reminder check interval
POLL_INTERVAL_MINUTES=10
REMINDER_CHECK_HOURS=24

# --- Claude vision fallback (optional) ----------------------------------------
# Used only for scanned/image PDFs that pdfplumber cannot read. Leave empty to
# disable entirely; unparseable invoices are then flagged for manual review.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Google APIs (only used when DEMO_MODE=false) ------------------------------
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
# Gmail search query used by the AP inbox watcher
GMAIL_QUERY=is:unread has:attachment label:supplier-invoices

# --- Company details (appear on invoices, reminders and reports) ----------------
COMPANY_NAME=Company A
COMPANY_EMAIL=accounts@example.com
COMPANY_ADDRESS=1 Example Street, Example Town, EX1 2MP
VAT_RATE=0.20

# --- AR rules --------------------------------------------------------------------
# Due date offset for new invoices, and days-overdue at which reminders go out
PAYMENT_TERMS_DAYS=14
REMINDER_DAYS=[7, 14, 30]

# --- Monthly report ----------------------------------------------------------------
# Comma-separated recipients of the monthly spend summary
REPORT_RECIPIENTS=finance@example.com

# --- Paths -----------------------------------------------------------------------
INVOICE_DIR=data/invoices
INBOUND_DIR=data/inbound
REPORT_DIR=data/reports
OUTBOX_DIR=data/outbox
SEED_OUTBOUND_FILE=seed/outbound_invoices.json
SEED_SUPPLIER_FILE=seed/supplier_invoices.json
